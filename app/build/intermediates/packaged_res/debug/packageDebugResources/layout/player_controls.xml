<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- 控件覆盖层 -->
    <LinearLayout
        android:id="@+id/controlsOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="#80000000"
        android:visibility="gone"
        android:padding="16dp">

        <!-- 顶部：标题 + 设置按钮 -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp">

            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentStart="true"
                android:layout_toStartOf="@+id/btnSettings"
                android:text=""
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/tvQuality"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_below="@id/tvTitle"
                android:layout_alignParentStart="true"
                android:text=""
                android:textColor="#80FFFFFF"
                android:textSize="12sp"
                android:layout_marginTop="2dp" />

            <ImageButton
                android:id="@+id/btnSettings"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:src="@android:drawable/ic_menu_manage"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="设置"
                android:tint="#FFFFFF" />
        </RelativeLayout>

        <!-- 中央：暂停/播放按钮 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:gravity="center">

            <ImageButton
                android:id="@+id/btnPlayPause"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:src="@android:drawable/ic_media_pause"
                android:scaleType="fitCenter"
                android:background="@drawable/circle_button_bg"
                android:contentDescription="暂停/播放"
                android:tint="#FFFFFF"
                android:padding="16dp" />
        </LinearLayout>

        <!-- 底部：进度条 + 时间 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <SeekBar
                android:id="@+id/seekBar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:max="1000"
                android:progressTint="#FF6750A4"
                android:thumbTint="#FF6750A4" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tvCurrentTime"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="00:00"
                    android:textColor="#CCFFFFFF"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/tvDuration"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="00:00"
                    android:textColor="#CCFFFFFF"
                    android:textSize="13sp" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <!-- VR 设置面板（默认隐藏） -->
    <LinearLayout
        android:id="@+id/settingsPanel"
        android:layout_width="320dp"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:orientation="vertical"
        android:background="@drawable/settings_panel_bg"
        android:padding="24dp"
        android:visibility="gone"
        android:elevation="8dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⚙ VR 显示设置"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="16dp" />

        <!-- SBS 3D 模式切换 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="SBS 3D 模式（左右分屏视频）"
                android:textColor="#CCFFFFFF"
                android:textSize="14sp" />

            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/switchSBS3D"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />
        </LinearLayout>

        <!-- 画面大小 -->
        <TextView
            android:id="@+id/tvScaleLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="画面大小: 85%"
            android:textColor="#CCFFFFFF"
            android:textSize="14sp"
            android:layout_marginBottom="4dp" />

        <SeekBar
            android:id="@+id/seekScale"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:min="50"
            android:max="100"
            android:progress="85"
            android:progressTint="#FF6750A4"
            android:thumbTint="#FF6750A4"
            android:layout_marginBottom="16dp" />

        <!-- 双屏间距 -->
        <TextView
            android:id="@+id/tvGapLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="双屏间距: 0"
            android:textColor="#CCFFFFFF"
            android:textSize="14sp"
            android:layout_marginBottom="4dp" />

        <SeekBar
            android:id="@+id/seekGap"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="1200"
            android:progress="600"
            android:progressTint="#FF6750A4"
            android:thumbTint="#FF6750A4"
            android:layout_marginBottom="16dp" />

        <!-- 畸变矫正 K1 -->
        <TextView
            android:id="@+id/tvK1Label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="畸变矫正 K1: 0.00"
            android:textColor="#CCFFFFFF"
            android:textSize="14sp"
            android:layout_marginBottom="4dp" />

        <SeekBar
            android:id="@+id/seekK1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="50"
            android:progress="0"
            android:progressTint="#FFF38BA8"
            android:thumbTint="#FFF38BA8"
            android:layout_marginBottom="16dp" />

        <!-- 畸变矫正 K2 -->
        <TextView
            android:id="@+id/tvK2Label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="畸变矫正 K2: 0.00"
            android:textColor="#CCFFFFFF"
            android:textSize="14sp"
            android:layout_marginBottom="4dp" />

        <SeekBar
            android:id="@+id/seekK2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="30"
            android:progress="0"
            android:progressTint="#FFF38BA8"
            android:thumbTint="#FFF38BA8"
            android:layout_marginBottom="16dp" />

        <!-- 关闭按钮 -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCloseSettings"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:text="关闭设置"
            android:textSize="14sp" />
    </LinearLayout>

</FrameLayout>
